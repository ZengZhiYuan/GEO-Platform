# App
APP_NAME=shipu-geo
APP_ENV=local
APP_DEBUG=true

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Frontend
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:8000/api

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=shipu_geo
POSTGRES_USER=shipu_geo
POSTGRES_PASSWORD=shipu_geo_password

DATABASE_URL=postgresql+psycopg2://shipu_geo:shipu_geo_password@localhost:5432/shipu_geo

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0

# AI Provider
AI_PROVIDER=openai_compatible
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=
AI_TIMEOUT_SECONDS=120

# Upload
UPLOAD_DIR=uploads
PUBLIC_FILE_BASE_URL=http://localhost:8000/static