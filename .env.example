# 本地开发：复制为 .env 后填入服务器 PostgreSQL、Redis、Nacos 的真实连接信息。
# 示例仅使用占位符，不得写入真实地址或密钥。
# 生产环境 APP_ENV=prod 时 fail-fast：DRAMATIQ_BROKER 必须为 redis；AGENT_LLM_BASE_URL、
# AGENT_LLM_API_KEY、AGENT_LLM_MODEL 必填；API_AUTH_ENABLED 必须为 true 且配置 API token；
# 启用模力指数时须显式设置 MOLIZHISHU_ENABLED、
# MOLIZHISHU_API_TOKEN、MOLIZHISHU_PROVIDER_BATCH_ENABLED（勿依赖代码默认值）。

APP_ENV=dev
APP_DEBUG=false
APP_TIMEZONE=Asia/Shanghai
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DATABASE_URL=postgresql+psycopg2://<user>:<password>@<server-host>:5432/geo_platform
# Optional isolated DB for migration integration tests (scripts/verify_migration_0004.ps1).
# MIGRATION_TEST_DATABASE_URL=postgresql+psycopg2://shipu_geo:shipu_geo_password@localhost:5432/geo_migration_test
REDIS_URL=redis://:<password>@<server-host>:6379/0
DRAMATIQ_BROKER=redis

NACOS_ENABLED=false
NACOS_SERVER_ADDRESSES=<server-host>:8848
NACOS_NAMESPACE=
NACOS_GROUP=DEFAULT_GROUP
NACOS_USERNAME=
NACOS_PASSWORD=
NACOS_CONFIG_DATA_ID=geo-platform-backend

COLLECTION_REQUEST_TIMEOUT_SECONDS=60
COLLECTION_MAX_ATTEMPTS=3
COLLECTION_RETRY_BASE_SECONDS=2
COLLECTION_AIDSO_MAX_POLLS=120
COLLECTION_MAX_CONCURRENCY=10
COLLECTION_RAW_RESPONSE_ENABLED=true
# 生产推荐按队列拆分 Dramatiq worker；本地 all-in-one worker 可继续使用 WORKER_PROCESSES/WORKER_THREADS
COLLECTION_WORKER_PROCESSES=4
COLLECTION_WORKER_THREADS=2
ANALYSIS_WORKER_PROCESSES=1
ANALYSIS_WORKER_THREADS=1
REPORT_WORKER_PROCESSES=1
REPORT_WORKER_THREADS=1

DOUBAO_ENABLED=false
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=
DOUBAO_API_KEYS=

QWEN_ENABLED=false
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=
QWEN_API_KEYS=

YUANBAO_ENABLED=false
YUANBAO_BASE_URL=https://hunyuan.tencentcloudapi.com
YUANBAO_MODEL=
YUANBAO_CREDENTIALS_JSON=[]

DEEPSEEK_ENABLED=false
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=
DEEPSEEK_API_KEYS=

KIMI_ENABLED=false
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=
KIMI_API_KEYS=

AIDSO_ENABLED=false
# 历史兼容：仅用于续跑历史 pending Aidso 任务；新建 Run 使用 collection_source=molizhishu，勿再启用 Aidso 新建采集
AIDSO_BASE_URL=https://odapi.aidso.com
AIDSO_API_TOKEN=

MOLIZHISHU_ENABLED=false
MOLIZHISHU_BASE_URL=https://business-api.molizhishu.com/api/business/monitor
MOLIZHISHU_API_TOKEN=
# 新建第三方采集：collection_source=molizhishu + molizhishu_* 平台码；关闭 MOLIZHISHU_ENABLED 不影响官方采集
# 真实接口手动 smoke：backend/scripts/molizhishu_smoke_test.py（可能产生费用，不写业务库）
MOLIZHISHU_REQUEST_TIMEOUT_SECONDS=30
COLLECTION_MOLIZHISHU_MAX_POLLS=360
COLLECTION_MOLIZHISHU_POLL_DELAY_SECONDS=8
# ProviderBatch 正式版：molizhishu run 按 prompts×platforms 自动拆批，单批最多 100 subtasks
MOLIZHISHU_PROVIDER_BATCH_ENABLED=true
MOLIZHISHU_PROVIDER_BATCH_MAX_SUBTASKS=100
MOLIZHISHU_DEFAULT_SCREENSHOT=0
# 模力指数 Run 未显式传 provider_screenshot 时的默认值；允许 0/1/2，语义与 RunCreate.provider_screenshot 一致
MOLIZHISHU_CALLBACK_ENABLED=false
MOLIZHISHU_CALLBACK_TOKEN=
# 回调鉴权使用 Header X-Callback-Token（与 MOLIZHISHU_CALLBACK_TOKEN 一致），勿写入 URL query
MOLIZHISHU_REGIONS_URL=https://business-api.molizhishu.com/api/business/eip-edge/ports/city-info
MOLIZHISHU_REGIONS_CACHE_SECONDS=300

AGENT_LLM_BASE_URL=
AGENT_LLM_API_KEY=
AGENT_LLM_MODEL=
AGENT_LLM_PROVIDER=openai_compatible
AGENT_LLM_TIMEOUT_SECONDS=90
AGENT_LLM_MAX_ATTEMPTS=2

# AI 生成辅助（O5）：优先 Agent LLM，失败或未配置时规则兜底
AI_GENERATION_LLM_ENABLED=true
AI_GENERATION_TIMEOUT_SECONDS=30
AI_GENERATION_MAX_INPUT_CHARS=4000

# 评价标签聚类（O6）：auto 先规则命中，样本足够且无规则命中时走 LLM；结果缓存于 run.result_json
EVALUATION_TAGS_LLM_ENABLED=true
EVALUATION_TAGS_LLM_MIN_ANSWERS=3
EVALUATION_TAGS_LLM_MAX_ANSWERS=50
EVALUATION_TAGS_LLM_TIMEOUT_SECONDS=30
EVALUATION_TAGS_LLM_MAX_INPUT_CHARS=8000

SCHEDULER_ENABLED=false
SCHEDULER_TIMEZONE=Asia/Shanghai
SCHEDULER_POLL_SECONDS=30

REPORT_STORAGE_DIR=./data/reports
REPORT_PUBLIC_BASE_URL=
REPORT_RETENTION_DAYS=90

# 业务 API 鉴权（O7）：生产 APP_ENV=prod 必须 API_AUTH_ENABLED=true 且配置 token
API_AUTH_ENABLED=false
API_AUTH_DEFAULT_TENANT_ID=1
API_AUTH_BEARER_TOKENS=
# 示例：[{"token":"<api-token>","tenant_id":1,"actor_id":1001}]
API_AUTH_TOKEN_MAP_JSON=[]
